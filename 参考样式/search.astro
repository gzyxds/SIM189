<!-- ===== 客户端交互脚本 ===== -->
<!-- 使用 define:vars 将 frontmatter 变量安全传递到 is:inline 脚本 -->
<script is:inline define:vars={{ clientProducts, clientErrors }}>
  /**
   * 榜单页客户端交互脚本
   *
   * 职责：
   * - 接收 Astro frontmatter 通过 define:vars 注入的商品数据
   * - 实现关键词搜索、榜单分类导航、快捷标签筛选
   * - 横向榜单行渲染（带排名序号）
   * - 分页加载（每次 12 条）与进度条展示
   * - 所有语法使用 ES5 兼容写法（var / function / 字符串拼接）
   */

  /** 商品数据（由 Astro define:vars 注入） */
  var rawProducts = clientProducts || [];
  var platformErrors = clientErrors || [];

  /** 运营商样式配色 */
  var OP_STYLE = {
    mobile: {
      badge: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
      dot: 'bg-green-500',
      gradient: 'from-green-500 to-emerald-600',
      light: 'bg-green-50 text-green-600 dark:bg-green-900/20 dark:text-green-400',
    },
    telecom: {
      badge: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
      dot: 'bg-blue-500',
      gradient: 'from-blue-500 to-blue-700',
      light: 'bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400',
    },
    unicom: {
      badge: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
      dot: 'bg-orange-500',
      gradient: 'from-orange-500 to-red-500',
      light: 'bg-orange-50 text-orange-600 dark:bg-orange-900/20 dark:text-orange-400',
    },
    broadcast: {
      badge: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
      dot: 'bg-purple-500',
      gradient: 'from-purple-500 to-indigo-600',
      light: 'bg-purple-50 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400',
    },
    unknown: {
      badge: 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400',
      dot: 'bg-gray-400',
      gradient: 'from-gray-400 to-gray-600',
      light: 'bg-gray-50 text-gray-600 dark:bg-gray-800 dark:text-gray-400',
    },
  };

  /** 平台角标配色 */
  var PLATFORM_BADGE = {
    '172haoka': 'bg-blue-500 text-white',
    haokavip: 'bg-red-500 text-white',
    linxi: 'bg-teal-500 text-white',
    yky: 'bg-indigo-500 text-white',
    gth: 'bg-amber-500 text-white',
  };

  /** 榜单标题映射 */
  var RANK_TITLES = {
    all: '今日榜单',
    recommend: '热销榜单',
    mobile: '中国移动榜单',
    telecom: '中国电信榜单',
    unicom: '中国联通榜单',
    broadcast: '中国广电榜单',
  };
  var TAG_TITLES = {
    long_term: '长期卡',
    short_term: '短期体验卡',
    price_9: '9元体验卡',
    low_price: '19元以下',
    price_29: '29元档',
    big_flow: '200G大流量',
    flow_100: '100G大流量',
    has_voice: '带通话',
    voice_100: '100分钟+',
  };

  /* ========== DOM 引用 ========== */
  var searchInput = document.getElementById('search-input');
  var searchClear = document.getElementById('search-clear');
  var searchGrid = document.getElementById('search-grid');
  var searchEmpty = document.getElementById('search-empty');
  var resultCount = document.getElementById('search-result-count');
  var loadBtn = document.getElementById('search-load-btn');
  var allLoaded = document.getElementById('search-all-loaded');
  var progressBar = document.getElementById('search-progress');
  var shownCount = document.getElementById('search-shown');
  var totalCountEl = document.getElementById('search-total');
  var rankTitle = document.getElementById('rank-title');

  /* ========== 状态 ========== */
  var PAGE_SIZE = 18;
  var activeTab = 'all';
  var activeTag = 'all';
  var searchQuery = '';
  var visibleCount = PAGE_SIZE;

  /* ========== 筛选匹配 ========== */

  /** 关键词搜索（空格分词 AND 匹配） */
  function matchSearch(name, query) {
    if (!query.trim()) return true;
    var tokens = query.trim().toLowerCase().split(/\s+/);
    var n = name.toLowerCase();
    return tokens.every(function (t) {
      return n.indexOf(t) !== -1;
    });
  }

  /** 运营商 Tab 匹配 */
  function matchTab(p) {
    if (activeTab === 'all') return true;
    if (activeTab === 'recommend') {
      /* 热销榜单：仅显示被标记为推荐、且满足以下任一条件的商品：
         - 月租在 9-39 元热门价格区间
         - 流量 >= 80GB
         避免与普通列表重复度过高 */
      if (!p.rc) return false;
      var goodPrice = p.pr >= 9 && p.pr <= 39;
      var goodFlow = p.fl >= 80;
      return goodPrice || goodFlow;
    }
    return p.op === activeTab;
  }

  /** 快捷标签匹配 */
  function matchTag(p) {
    switch (activeTag) {
      case 'all':
        return true;
      case 'long_term':
        return p.du === '长期';
      case 'short_term':
        return p.du !== '长期' && p.du !== '' && p.du !== '未知';
      case 'price_9':
        return p.pr > 0 && p.pr <= 9;
      case 'low_price':
        return p.pr > 0 && p.pr <= 19;
      case 'price_29':
        return p.pr >= 25 && p.pr <= 35;
      case 'big_flow':
        return p.fl >= 200;
      case 'flow_100':
        return p.fl >= 100;
      case 'has_voice':
        return p.vo > 0;
      case 'voice_100':
        return p.vo >= 100;
      default:
        return true;
    }
  }

  /** 获取筛选后的商品列表 */
  function getFiltered() {
    return rawProducts.filter(function (p) {
      return matchTab(p) && matchTag(p) && matchSearch(p.n, searchQuery);
    });
  }

  /* ========== 卡片渲染 ========== */

  /**
   * 渲染单个商品卡片
   *
   * 极简文案优先设计，清晰的信息层级：
   *   商品名称 → 标签行（运营商/平台/排名）→ 参数文案 → 价格+按钮
   *   无多余装饰色块，以排版和字体粗细区分层级
   *
   * @param p - 当前商品数据
   * @param rank - 当前商品排名
   * @param delay - 动画延迟毫秒数
   * @returns 商品卡片 HTML 字符串
   */
  function renderRow(p, rank, delay) {
    var opStyle = OP_STYLE[p.op] || OP_STYLE.unknown;
    var pfBadge = PLATFORM_BADGE[p.pf] || 'bg-gray-500 text-white';
    var animStyle = delay ? ' style="animation-delay:' + delay + 'ms"' : '';

    /* 排名标识（纯文字，TOP 1-3 高亮色，其余灰色序号） */
    var rankText = '';
    if (rank === 1) {
      rankText = '<span class="text-[11px] font-bold text-amber-500">No.1</span>';
    } else if (rank === 2) {
      rankText = '<span class="text-[11px] font-bold text-gray-400">No.2</span>';
    } else if (rank === 3) {
      rankText = '<span class="text-[11px] font-bold text-amber-700">No.3</span>';
    } else if (rank <= 12) {
      rankText =
        '<span class="text-[11px] font-medium text-gray-300 dark:text-gray-600">No.' +
        rank +
        '</span>';
    }

    /* 热销标识 */
    var recText = p.rc ? '<span class="text-[11px] font-semibold text-red-400">热销</span>' : '';

    /* 运营商 + 平台标签（纯文字，用中点分隔） */
    var metaParts = [];
    metaParts.push(
      '<span class="font-medium ' +
        opStyle.badge.replace(/rounded-md|px-1\.5/g, '').trim() +
        '">' +
        p.ol +
        '</span>'
    );
    metaParts.push('<span class="text-gray-300 dark:text-gray-600">\xB7</span>');
    metaParts.push('<span class="text-gray-400">' + p.pl + '</span>');
    if (p.re) {
      metaParts.push('<span class="text-gray-300 dark:text-gray-600">\xB7</span>');
      metaParts.push('<span class="text-gray-400">' + p.re + '</span>');
    }
    if (rankText) {
      metaParts.push('<span class="text-gray-200 dark:text-gray-700 mx-0.5">|</span>');
      metaParts.push(rankText);
    }
    if (recText) {
      metaParts.push('<span class="text-gray-200 dark:text-gray-700 mx-0.5">|</span>');
      metaParts.push(recText);
    }
    var metaHtml =
      '<div class="flex flex-wrap items-center gap-x-1.5 text-[12px]">' +
      metaParts.join('') +
      '</div>';

    /* 核心参数行 — 简洁文案式，用竖线分隔 */
    var specs = [];
    if (p.fl > 0)
      specs.push(
        '<span class="font-medium text-gray-700 dark:text-gray-300">' + p.fl + 'GB</span>'
      );
    if (p.vo > 0)
      specs.push(
        '<span class="font-medium text-gray-700 dark:text-gray-300">' + p.vo + '分钟</span>'
      );
    if (p.du && p.du !== '\u672A\u77E5')
      specs.push('<span class="font-medium text-gray-700 dark:text-gray-300">' + p.du + '</span>');
    var specsHtml =
      specs.length > 0
        ? '<div class="flex items-center gap-2 text-[13px] text-gray-400 dark:text-gray-500">' +
          specs.join('<span class="h-3 w-px bg-gray-200 dark:bg-gray-700"></span>') +
          '</div>'
        : '';

    /* 月租价格 */
    var priceHtml =
      p.pr > 0
        ? '<span class="text-lg font-bold text-gray-900 dark:text-white">' +
          p.pr +
          '<span class="text-xs font-normal text-gray-400">元/月</span></span>'
        : '<span class="text-sm text-gray-400">面议</span>';

    /* 操作按钮 */
    var orderLink = p.o || p.d;
    var isExternalOrder = !!p.o && p.o !== p.d;
    var orderTarget = isExternalOrder ? ' target="_blank" rel="noopener noreferrer"' : '';

    return (
      '<div class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white transition-all duration-200 hover:border-gray-200 hover:shadow-lg hover:shadow-black/[0.04] dark:border-dark-3 dark:bg-dark-2 dark:hover:border-dark-3/60 card-animate"' +
      animStyle +
      '>' +
      /* 全局点击跳转覆盖层 */
      '<a href="' +
      p.d +
      '" class="absolute inset-0 z-20" aria-label="' +
      p.n.replace(/"/g, '&quot;') +
      '"></a>' +
      /* 卡片主体 */
      '<div class="flex flex-1 flex-col p-5">' +
      /* 第一层：运营商/平台/排名 标签行 */
      metaHtml +
      /* 第二层：商品名称 */
      '<h3 class="mt-3 mb-3 line-clamp-2 text-[15px] font-medium leading-snug text-gray-900 transition-colors group-hover:text-primary dark:text-white dark:group-hover:text-primary">' +
      p.n +
      '</h3>' +
      /* 第三层：核心参数 */
      '<div class="mb-4 min-h-[20px]">' +
      specsHtml +
      '</div>' +
      /* 弹性占位 */
      '<div class="flex-1"></div>' +
      /* 第四层：价格 + 办理按钮 */
      '<div class="mt-auto flex items-center justify-between border-t border-gray-50 pt-3 dark:border-dark-3">' +
      priceHtml +
      '<a href="' +
      orderLink +
      '"' +
      orderTarget +
      ' class="relative z-30 text-[12px] font-medium text-primary hover:underline" onclick="event.stopPropagation();">' +
      '办理 →' +
      '</a>' +
      '</div>' +
      '</div>' +
      '</div>'
    );
  }

  /* ========== 渲染 ========== */

  /** 更新榜单标题 */
  function updateRankTitle() {
    if (!rankTitle) return;
    var t = RANK_TITLES[activeTab] || '今日榜单';
    if (activeTag !== 'all') {
      t = t + ' \xB7 ' + (TAG_TITLES[activeTag] || '');
    }
    rankTitle.textContent = t;
  }

  /** 渲染榜单列表 */
  function render() {
    if (!searchGrid) return;
    var filtered = getFiltered();
    var displayed = filtered.slice(0, visibleCount);
    var hasMore = displayed.length < filtered.length;

    /** 更新计数 */
    if (resultCount) resultCount.textContent = String(filtered.length);
    if (totalCountEl) totalCountEl.textContent = String(filtered.length);
    if (shownCount) shownCount.textContent = String(displayed.length);

    /** 空态显隐 */
    if (searchEmpty) searchEmpty.classList.toggle('hidden', filtered.length > 0);
    searchGrid.classList.toggle('hidden', filtered.length === 0);

    /** 渲染卡片，添加交错淡入动画 */
    var html = '';
    for (var idx = 0; idx < displayed.length; idx++) {
      var delay = (idx % 3) * 80;
      html += renderRow(displayed[idx], idx + 1, delay);
    }
    searchGrid.innerHTML = html;

    /** 加载更多按钮 */
    if (hasMore) {
      if (loadBtn) loadBtn.classList.remove('hidden');
      if (allLoaded) allLoaded.classList.add('hidden');
      var remaining = filtered.length - displayed.length;
      if (loadBtn) {
        loadBtn.innerHTML =
          '<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>' +
          '加载更多（还有 ' +
          remaining +
          ' 款）';
      }
    } else {
      if (loadBtn) loadBtn.classList.add('hidden');
      if (allLoaded) allLoaded.classList.toggle('hidden', filtered.length === 0);
    }

    /** 进度条 */
    if (filtered.length > 0 && progressBar) {
      progressBar.style.width = Math.round((displayed.length / filtered.length) * 100) + '%';
    }
  }

  /* ========== 事件绑定 ========== */

  /** Tab / 分类点击（左侧边栏） */
  function onTabClick(tab) {
    if (activeTag !== 'all') activeTag = 'all';
    activeTab = tab;
    visibleCount = PAGE_SIZE;
    updateTabs();
    updateTags();
    updateRankTitle();
    render();
  }

  /** Tag 点击（快捷筛选） */
  function onTagClick(tag) {
    if (activeTab !== 'all') activeTab = 'all';
    activeTag = tag;
    visibleCount = PAGE_SIZE;
    updateTabs();
    updateTags();
    updateRankTitle();
    render();
  }

  document.querySelectorAll('.search-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (btn.dataset.tab) onTabClick(btn.dataset.tab);
      if (btn.dataset.tag) onTagClick(btn.dataset.tag);
    });
  });

  document.querySelectorAll('.quick-tag').forEach(function (btn) {
    btn.addEventListener('click', function () {
      onTagClick(btn.dataset.tag || 'all');
    });
  });

  /** 搜索输入 */
  if (searchInput) {
    searchInput.addEventListener('input', function () {
      searchQuery = searchInput.value;
      visibleCount = PAGE_SIZE;
      if (searchClear) searchClear.classList.toggle('hidden', !searchQuery);
      render();
    });
  }

  /** 清除搜索 */
  if (searchClear) {
    searchClear.addEventListener('click', function () {
      if (searchInput) searchInput.value = '';
      searchQuery = '';
      searchClear.classList.add('hidden');
      visibleCount = PAGE_SIZE;
      render();
    });
  }

  /** 加载更多 */
  if (loadBtn) {
    loadBtn.addEventListener('click', function () {
      visibleCount += PAGE_SIZE;
      render();
    });
  }

  /** 更新左侧边栏 Tab 样式 */
  function updateTabs() {
    document.querySelectorAll('.search-tab').forEach(function (b) {
      var isActive = false;
      if (b.dataset.tab && b.dataset.tab === activeTab && activeTag === 'all') {
        isActive = true;
      }
      if (b.dataset.tag && b.dataset.tag === activeTag) {
        isActive = true;
      }
      /** active 状态 */
      b.classList.toggle('bg-primary/5', isActive);
      b.classList.toggle('text-primary', isActive);
      b.classList.toggle('dark:bg-primary/10', isActive);
      /** inactive 状态 */
      b.classList.toggle('text-gray-600', !isActive);
      b.classList.toggle('dark:text-gray-300', !isActive);
      b.classList.toggle('hover:bg-gray-50', !isActive);
      b.classList.toggle('dark:hover:bg-dark-3', !isActive);
    });
  }

  /** 更新右侧快捷标签样式 */
  function updateTags() {
    document.querySelectorAll('.quick-tag').forEach(function (b) {
      var isActive = b.dataset.tag === activeTag;
      b.classList.toggle('bg-primary', isActive);
      b.classList.toggle('text-white', isActive);
      b.classList.toggle('border-gray-200', !isActive);
      b.classList.toggle('bg-white', !isActive);
      b.classList.toggle('text-gray-600', !isActive);
      b.classList.toggle('dark:border-dark-3', !isActive);
      b.classList.toggle('dark:bg-dark-3', !isActive);
      b.classList.toggle('dark:text-gray-400', !isActive);
    });
  }

  /* ========== 初始化入口 ========== */
  function initSearch() {
    updateRankTitle();
    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
</script>

<style>
  /** 隐藏横向滚动条但保留触摸滚动 */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /** 卡片淡入动画 */
  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .card-animate {
    animation: cardFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>
