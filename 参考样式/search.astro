---
/**
 * 全局搜索页 — 聚合多平台号卡商品
 *
 * 并行拉取 5 大平台（172号卡/浩卡联盟/林夕通信/翼卡云/卡业联盟）商品数据，
 * 统一映射为 SearchProduct 格式。客户端支持：
 * - 关键词搜索（大小写不敏感，空格分词 AND 匹配）
 * - 运营商分类 Tab（全部/推荐/移动/电信/联通/广电）
 * - 快捷标签筛选（长期卡/低月租/大流量/带通话）
 * - 点击加载更多分页
 *
 * 路由：/search
 * 数据来源：复用各平台 lib/api 模块的 fetchXxx() 函数
 */
import Layout from '../layouts/Layout.astro';
import SEOSchema from '../components/SEOSchema.astro';

/* ========== 平台 API 导入 ========== */
import { fetchProducts, getOrderPageUrl } from '../lib/haoka-api';
import { fetchAllHaokaVipProducts, getHaokaVipProductLink } from '../lib/haokavip-api';
import { fetchLinxiProducts, getLinxiOrderUrl } from '../lib/linxi-api';
import { fetchYkyProducts, getYkyOrderUrl } from '../lib/yky-api';
import {
  fetchAllGthProducts,
  getGthProductLink,
  isGthSimCard,
  parseGthPrice,
  parseGthFlow,
  parseGthVoice,
  detectGthOperator,
} from '../lib/gantanhao-api';

import type { HaokaProduct } from '../lib/haoka-api';
import type { HaokaVipProduct } from '../lib/haokavip-api';
import type { LinxiProduct } from '../lib/linxi-api';
import type { YkyProductWithMeta } from '../lib/yky-api';
import type { GthProduct } from '../lib/gantanhao-api';

/* ========== 统一搜索商品类型 ========== */

/** 运营商枚举 */
type SearchOperator = 'mobile' | 'telecom' | 'unicom' | 'broadcast' | 'unknown';

/** 平台标识 */
type SearchPlatform = '172haoka' | 'haokavip' | 'linxi' | 'yky' | 'gth';

/** 统一搜索商品模型 */
interface SearchProduct {
  id: string;
  name: string;
  /** 详情页路由 */
  detailUrl: string;
  /** 办理链接（外链） */
  orderUrl: string;
  /** 平台标识 */
  platform: SearchPlatform;
  /** 运营商 */
  operator: SearchOperator;
  /** 月租（元），0 表示面议 */
  price: number;
  /** 通用流量（GB） */
  flow: number;
  /** 通话时长（分钟） */
  voice: number;
  /** 套餐时长 */
  duration: string;
  /** 归属地/地区 */
  region: string;
  /** 是否推荐 */
  isRecommend: boolean;
  /** 运营商中文标签 */
  operatorLabel: string;
  /** 平台中文标签 */
  platformLabel: string;
}

/* ========== 工具函数 ========== */

/** 从文本中提取月租价格 */
function parsePrice(text: string): number {
  const m = text.match(/(\d+\.?\d*)元/);
  return m ? parseFloat(m[1]) : 0;
}

/** 从文本中提取流量 GB */
function parseFlow(text: string): number {
  const m = text.match(/(\d+\.?\d*)\s*(?:GB|G)/i);
  return m ? parseFloat(m[1]) : 0;
}

/** 从文本中提取通话分钟 */
function parseVoice(text: string): number {
  const m = text.match(/(\d+)\s*分钟/);
  return m ? parseInt(m[1]) : 0;
}

/** 从商品名称识别运营商 */
function detectOperator(name: string): SearchOperator {
  const n = name.toLowerCase();
  if (n.includes('移动')) return 'mobile';
  if (n.includes('电信')) return 'telecom';
  if (n.includes('联通')) return 'unicom';
  if (n.includes('广电')) return 'broadcast';
  return 'unknown';
}

/** 运营商中文标签 */
const OPERATOR_LABEL: Record<string, string> = {
  mobile: '移动',
  telecom: '电信',
  unicom: '联通',
  broadcast: '广电',
  unknown: '其他',
};

/** 平台中文标签 */
const PLATFORM_LABEL: Record<SearchPlatform, string> = {
  '172haoka': '172',
  haokavip: '浩卡',
  linxi: '林夕',
  yky: '翼卡云',
  gth: '卡业联盟',
};

/* ========== 数据获取 ========== */

/** 并行拉取所有平台数据 */
const [haokaRes, haokavipRes, linxiRes, ykyRes, gthRes] = await Promise.allSettled([
  fetchProducts(),
  fetchAllHaokaVipProducts(),
  fetchLinxiProducts(),
  fetchYkyProducts(),
  fetchAllGthProducts(),
]);

const allProducts: SearchProduct[] = [];
const platformErrors: string[] = [];

/* ===== 172号卡 ===== */
if (haokaRes.status === 'fulfilled') {
  allProducts.push(
    ...haokaRes.value.map((p: HaokaProduct) => ({
      id: `172-${p.productID}`,
      name: p.productName,
      detailUrl: `/Product/${p.productID}`,
      orderUrl: getOrderPageUrl(p.productID),
      platform: '172haoka' as SearchPlatform,
      operator: detectOperator(p.productName),
      price: parsePrice(p.productName + p.taocan),
      flow: parseFlow(p.taocan),
      voice: parseVoice(p.taocan),
      duration: p.priceTime || '未知',
      region: p.area || '',
      isRecommend: p.flag || false,
      operatorLabel: OPERATOR_LABEL[detectOperator(p.productName)] || '其他',
      platformLabel: '172',
    }))
  );
} else {
  platformErrors.push('172号卡');
}

/* ===== 浩卡联盟 ===== */
if (haokavipRes.status === 'fulfilled') {
  allProducts.push(
    ...haokavipRes.value.map((p: HaokaVipProduct) => ({
      id: `hkvip-${p.product_id}`,
      name: p.product_name,
      detailUrl: `/haoka/${p.product_id}`,
      orderUrl: getHaokaVipProductLink(p.product_link || ''),
      platform: 'haokavip' as SearchPlatform,
      operator: detectOperator(p.product_name),
      price: parsePrice(p.product_name),
      flow: parseFlow(p.product_name),
      voice: parseVoice(p.product_name),
      duration: '未知',
      region: '',
      isRecommend: p.is_recommend === 1,
      operatorLabel: OPERATOR_LABEL[detectOperator(p.product_name)] || '其他',
      platformLabel: '浩卡',
    }))
  );
} else {
  platformErrors.push('浩卡联盟');
}

/* ===== 林夕通信 ===== */
if (linxiRes.status === 'fulfilled') {
  allProducts.push(
    ...linxiRes.value.map((p: LinxiProduct) => ({
      id: `linxi-${p.id}`,
      name: p.shop_name,
      detailUrl: `/shop/${p.id}`,
      orderUrl: getLinxiOrderUrl(p.id),
      platform: 'linxi' as SearchPlatform,
      operator: detectOperator(p.shop_name),
      price: parsePrice(p.shop_name),
      flow: parseFlow(p.shop_name),
      voice: parseVoice(p.shop_name),
      duration: '未知',
      region: p.gsd_province || '',
      isRecommend: false,
      operatorLabel: OPERATOR_LABEL[detectOperator(p.shop_name)] || '其他',
      platformLabel: '林夕',
    }))
  );
} else {
  platformErrors.push('林夕通信');
}

/* ===== 翼卡云 ===== */
if (ykyRes.status === 'fulfilled' && ykyRes.value.products) {
  allProducts.push(
    ...ykyRes.value.products.map((p: YkyProductWithMeta) => ({
      id: `yky-${p.id}`,
      name: p.name,
      detailUrl: `/yky/${p.id}`,
      orderUrl: p._orderUrl || getYkyOrderUrl(p.id),
      platform: 'yky' as SearchPlatform,
      operator: p._operator as SearchOperator,
      price: p.favourMonthFee || p.monthFee || 0,
      flow: p.commonFlow || 0,
      voice: p.callDuration || 0,
      duration: p._duration || '未知',
      region: p._region || '',
      isRecommend: false,
      operatorLabel: OPERATOR_LABEL[p._operator] || '其他',
      platformLabel: '翼卡云',
    }))
  );
} else {
  platformErrors.push('翼卡云');
}

/* ===== 卡业联盟 ===== */
if (gthRes.status === 'fulfilled') {
  const gthProducts = gthRes.value.filter(isGthSimCard);
  allProducts.push(
    ...gthProducts.map((p: GthProduct) => ({
      id: `gth-${p.codeNumber}`,
      name: p.name,
      detailUrl: `/gth/${p.codeNumber}`,
      orderUrl: getGthProductLink(p.codeNumber),
      platform: 'gth' as SearchPlatform,
      operator: detectGthOperator(p.type) as SearchOperator,
      price: parseGthPrice(p.name),
      flow: parseGthFlow(p.subName),
      voice: parseGthVoice(p.subName),
      duration: p.packageContract || '未知',
      region: p.location || '',
      isRecommend: false,
      operatorLabel:
        detectGthOperator(p.type) === 'mobile'
          ? '移动'
          : detectGthOperator(p.type) === 'telecom'
            ? '电信'
            : detectGthOperator(p.type) === 'unicom'
              ? '联通'
              : detectGthOperator(p.type) === 'broadcast'
                ? '广电'
                : '其他',
      platformLabel: '卡业联盟',
    }))
  );
} else {
  platformErrors.push('卡业联盟');
}

/** 按推荐优先 + 排序 */
allProducts.sort((a, b) => {
  if (a.isRecommend !== b.isRecommend) return b.isRecommend ? 1 : -1;
  return a.price - b.price;
});

const totalCount = allProducts.length;

/** 客户端用轻量商品数据（字段缩写减少传输） */
const clientProducts = allProducts.map((p) => ({
  i: p.id,
  n: p.name,
  d: p.detailUrl,
  o: p.orderUrl,
  pf: p.platform,
  op: p.operator,
  pr: p.price,
  fl: p.flow,
  vo: p.voice,
  du: p.duration,
  re: p.region,
  rc: p.isRecommend,
  ol: p.operatorLabel,
  pl: p.platformLabel,
}));

/** 客户端用平台错误列表 */
const clientErrors = platformErrors;
